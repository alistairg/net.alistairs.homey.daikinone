{
  "name": {
    "en": "Daikin One Thermostat"
  },
  "class": "thermostat",
  "capabilities": [
    "target_temperature",
    "measure_temperature",
    "measure_humidity",
    "thermostat_mode",
    "equipment_status",
    "outdoor_temperature",
    "outdoor_humidity",
    "schedule_enabled"
  ],
  "capabilitiesOptions": {
    "target_temperature": {
      "min": 5,
      "max": 40,
      "step": 0.5
    },
    "target_temperature.heat": {
      "title": { "en": "Heating Target" },
      "min": 5,
      "max": 40,
      "step": 0.5
    },
    "target_temperature.cool": {
      "title": { "en": "Cooling Target" },
      "min": 5,
      "max": 40,
      "step": 0.5
    },
    "thermostat_mode": {
      "values": [
        { "id": "off", "title": { "en": "Off" } },
        { "id": "heat", "title": { "en": "Heat" } },
        { "id": "cool", "title": { "en": "Cool" } },
        { "id": "auto", "title": { "en": "Auto" } }
      ]
    }
  },
  "energy": {
    "approximation": {
      "usageOn": 0,
      "usageOff": 0
    }
  },
  "pair": [
    {
      "id": "login_credentials",
      "template": "login_credentials",
      "options": {
        "title": { "en": "Daikin One" },
        "usernameLabel": { "en": "Email" },
        "usernamePlaceholder": { "en": "SkyportHome account email" },
        "passwordLabel": { "en": "Integrator Token" },
        "passwordPlaceholder": { "en": "Long token (JWE) from Daikin" }
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "images": {
    "small": "/drivers/thermostat/assets/images/small.png",
    "large": "/drivers/thermostat/assets/images/large.png"
  }
}
